# Copy to .env for local dev — never commit .env
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...

JWT_SECRET=any-long-random-string-you-choose

# WebAuthn — must match the actual domain (no trailing slash)
# Local:
RP_ID=localhost
RP_ORIGIN=http://localhost:3001
# Production (set these on Vercel instead):
# RP_ID=your-app.vercel.app
# RP_ORIGIN=https://your-app.vercel.app
